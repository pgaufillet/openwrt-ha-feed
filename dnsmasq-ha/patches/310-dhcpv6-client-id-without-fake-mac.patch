From: OpenWrt HA build <local>
Subject: [PATCH] dnsmasq-ha: inject DHCPv6 leases by client-id without fake MAC

Forward DHCPv6 client identifiers to dhcp-script/hotplug and make ubus
add_lease require MAC addresses only for IPv4. DHCPv6 lease injection now uses
the real client-id/DUID plus IAID and no longer needs placeholder MAC values
such as "00".

--- a/src/helper.c	2025-12-07 15:44:40.000000000 +0200
+++ b/src/helper.c	2026-05-09 13:31:14.449047143 +0300
@@ -589,7 +589,7 @@
 	  my_setenv("DNSMASQ_MAC", is6 && data.hwaddr_len != 0 ? daemon->dhcp_buff : NULL, &err);
 #endif
 	  
-	  my_setenv("DNSMASQ_CLIENT_ID", !is6 && data.clid_len != 0 ? daemon->packet : NULL, &err);
+	  my_setenv("DNSMASQ_CLIENT_ID", data.clid_len != 0 ? daemon->packet : NULL, &err);
 	  my_setenv("DNSMASQ_INTERFACE", strlen(data.interface) != 0 ? data.interface : NULL, &err);
 	  
 #ifdef HAVE_BROKEN_RTC
--- a/src/ubus.c	2026-05-09 13:32:23.000927662 +0300
+++ b/src/ubus.c	2026-05-09 13:31:48.554857633 +0300
@@ -280,12 +280,13 @@
 {
   struct blob_attr *tb[__ADD_LEASE_MAX];
   struct dhcp_lease *lease;
-  const char *ipaddr, *hwaddr, *hostname, *client_id;
+  const char *ipaddr, *hwaddr = NULL, *hostname, *client_id;
   union all_addr addr;
-  unsigned char hwaddr_bin[DHCP_CHADDR_MAX];
+  unsigned char hwaddr_bin[DHCP_CHADDR_MAX] = { 0 };
   unsigned char clid_bin[256];
   char hwaddr_str[DHCP_CHADDR_MAX * 3 + 1];
-  int hw_len, hw_type, clid_len = 0;
+  char lease_id_str[256 * 3 + 16];
+  int hw_len = 0, hw_type = ARPHRD_ETHER, clid_len = 0;
   int i;
   time_t now = dnsmasq_time();
   uint32_t expires;
@@ -299,14 +300,15 @@
 
   blobmsg_parse(add_lease_policy, __ADD_LEASE_MAX, tb, blob_data(msg), blob_len(msg));
 
-  if (!tb[ADD_LEASE_IP] || !tb[ADD_LEASE_MAC] || !tb[ADD_LEASE_EXPIRES])
+  if (!tb[ADD_LEASE_IP] || !tb[ADD_LEASE_EXPIRES])
     {
-      my_syslog(LOG_ERR, _("UBus add_lease: missing required parameters (ip, mac, expires)"));
+      my_syslog(LOG_ERR, _("UBus add_lease: missing required parameters (ip, expires)"));
       return UBUS_STATUS_INVALID_ARGUMENT;
     }
 
   ipaddr = blobmsg_get_string(tb[ADD_LEASE_IP]);
-  hwaddr = blobmsg_get_string(tb[ADD_LEASE_MAC]);
+  if (tb[ADD_LEASE_MAC])
+    hwaddr = blobmsg_get_string(tb[ADD_LEASE_MAC]);
   expires = blobmsg_get_u32(tb[ADD_LEASE_EXPIRES]);
 
   hostname = tb[ADD_LEASE_HOSTNAME] ? blobmsg_get_string(tb[ADD_LEASE_HOSTNAME]) : NULL;
@@ -324,36 +326,12 @@
       return UBUS_STATUS_INVALID_ARGUMENT;
     }
 
-  hw_len = parse_hex((char*)hwaddr, hwaddr_bin, DHCP_CHADDR_MAX, NULL, &hw_type);
-  if (hw_len <= 0)
-    {
-      my_syslog(LOG_ERR, _("UBus add_lease: invalid MAC address '%s'"), hwaddr);
-      return UBUS_STATUS_INVALID_ARGUMENT;
-    }
-
-  if (hw_type == 0)
-    hw_type = ARPHRD_ETHER;
-
-  if (client_id && *client_id)
-    {
-      clid_len = parse_hex((char*)client_id, clid_bin, sizeof(clid_bin), NULL, NULL);
-      if (clid_len < 0)
-	{
-	  my_syslog(LOG_WARNING, _("UBus add_lease: invalid client_id '%s', ignoring"), client_id);
-	  clid_len = 0;
-	}
-    }
-
   if (hostname && *hostname && !legal_hostname((char *)hostname))
     {
       my_syslog(LOG_ERR, _("UBus add_lease: invalid hostname '%s'"), hostname);
       return UBUS_STATUS_INVALID_ARGUMENT;
     }
 
-  for (i = 0; i < hw_len; i++)
-    sprintf(hwaddr_str + i * 3, "%02x:", hwaddr_bin[i]);
-  hwaddr_str[hw_len * 3 - 1] = '\0';
-
   if (inet_pton(AF_INET, ipaddr, &addr.addr4))
     {
       if (!daemon->dhcp)
@@ -368,6 +346,32 @@
 	  return UBUS_STATUS_INVALID_ARGUMENT;
 	}
 
+      if (!hwaddr || !*hwaddr)
+	{
+	  my_syslog(LOG_ERR, _("UBus add_lease: MAC address is required for IPv4 lease %s"), ipaddr);
+	  return UBUS_STATUS_INVALID_ARGUMENT;
+	}
+
+      hw_len = parse_hex((char*)hwaddr, hwaddr_bin, DHCP_CHADDR_MAX, NULL, &hw_type);
+      if (hw_len <= 0)
+	{
+	  my_syslog(LOG_ERR, _("UBus add_lease: invalid MAC address '%s'"), hwaddr);
+	  return UBUS_STATUS_INVALID_ARGUMENT;
+	}
+
+      if (hw_type == 0)
+	hw_type = ARPHRD_ETHER;
+
+      if (client_id && *client_id)
+	{
+	  clid_len = parse_hex((char*)client_id, clid_bin, sizeof(clid_bin), NULL, NULL);
+	  if (clid_len < 0)
+	    {
+	      my_syslog(LOG_WARNING, _("UBus add_lease: invalid client_id '%s', ignoring"), client_id);
+	      clid_len = 0;
+	    }
+	}
+
       if (!(lease = lease_find_by_addr(addr.addr4)))
 	lease = lease4_allocate(addr.addr4);
     }
@@ -380,6 +384,32 @@
 	  return UBUS_STATUS_INVALID_ARGUMENT;
 	}
 
+      if (!client_id || !*client_id || !tb[ADD_LEASE_IA_ID])
+	{
+	  my_syslog(LOG_ERR, _("UBus add_lease: client_id and iaid are required for DHCPv6 lease %s"), ipaddr);
+	  return UBUS_STATUS_INVALID_ARGUMENT;
+	}
+
+      clid_len = parse_hex((char*)client_id, clid_bin, sizeof(clid_bin), NULL, NULL);
+      if (clid_len <= 0)
+	{
+	  my_syslog(LOG_ERR, _("UBus add_lease: invalid DHCPv6 client_id '%s'"), client_id);
+	  return UBUS_STATUS_INVALID_ARGUMENT;
+	}
+
+      if (hwaddr && *hwaddr)
+	{
+	  hw_len = parse_hex((char*)hwaddr, hwaddr_bin, DHCP_CHADDR_MAX, NULL, &hw_type);
+	  if (hw_len <= 0)
+	    {
+	      my_syslog(LOG_WARNING, _("UBus add_lease: invalid DHCPv6 MAC '%s', ignoring"), hwaddr);
+	      hw_len = 0;
+	      hw_type = ARPHRD_ETHER;
+	    }
+	  else if (hw_type == 0)
+	    hw_type = ARPHRD_ETHER;
+	}
+
       if ((lease = lease6_find_by_addr(&addr.addr6, 128, 0)))
 	{
 	  if (lease->iaid != ia_id)
@@ -409,6 +439,18 @@
       return UBUS_STATUS_UNKNOWN_ERROR;
     }
 
+  if (hw_len > 0)
+    {
+      for (i = 0; i < hw_len; i++)
+	sprintf(hwaddr_str + i * 3, "%02x:", hwaddr_bin[i]);
+      hwaddr_str[hw_len * 3 - 1] = '\0';
+      snprintf(lease_id_str, sizeof(lease_id_str), "%s", hwaddr_str);
+    }
+  else if (client_id && *client_id)
+    snprintf(lease_id_str, sizeof(lease_id_str), "client_id=%s", client_id);
+  else
+    snprintf(lease_id_str, sizeof(lease_id_str), "no-mac");
+
   lease_set_hwaddr(lease, hwaddr_bin, clid_len > 0 ? clid_bin : NULL,
 		   hw_len, hw_type, clid_len, now, 0);
 
@@ -434,7 +476,7 @@
   lease->flags &= ~(LEASE_NEW | LEASE_CHANGED | LEASE_AUX_CHANGED | LEASE_EXP_CHANGED);
 
   my_syslog(LOG_INFO, _("UBus add_lease: added %s %s %s"),
-	    ipaddr, hwaddr_str, hostname ? hostname : "");
+	    ipaddr, lease_id_str, hostname ? hostname : "");
 
   return UBUS_STATUS_OK;
 }
