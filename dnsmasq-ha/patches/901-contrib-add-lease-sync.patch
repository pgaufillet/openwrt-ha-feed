+struct daemon_state *g_state = NULL;
+
+static void reset_state(void)
+{
+    memset(&state_storage, 0, sizeof(state_storage));
+    g_state = &state_storage;
+    g_state->config.log_level = LOG_LEVEL_ERROR;  /* Suppress debug logs */
