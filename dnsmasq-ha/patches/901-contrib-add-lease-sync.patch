new file mode 100644
index 0000000..bec5b7c
--- /dev/null
+++ b/contrib/lease-sync/dnsmasq-ha.conf.example
@@ -0,0 +1,166 @@
+# Example dnsmasq configuration for High Availability setup
+# This configuration works with dhcp-script-ha.sh and lease-sync daemon
+#
+# Installation:
+#   cp dnsmasq-ha.conf.example /etc/dnsmasq.d/ha.conf
+#   /etc/init.d/dnsmasq restart
+
+# ============================================
+# Basic DHCP Configuration
+# ============================================
+
+# Enable DHCP server
+dhcp-range=192.168.1.50,192.168.1.200,12h
+
+# Set the domain for dnsmasq
+domain=lan
+
+# Set authoritative mode (recommended for HA to prevent delays)
+dhcp-authoritative
+
+# ============================================
+# High Availability Configuration
+# ============================================
+
+# DHCP event script for lease synchronization
+# This script publishes lease events to ubus for the lease-sync daemon
+dhcp-script=/usr/lib/dnsmasq/dhcp-script-ha.sh
+
+# Optional: Run script as non-root user (recommended for security)
+# dhcp-scriptuser=nobody
+
+# Optional: Enable script on lease renewals and expiry changes
+# Useful for keeping peer nodes updated on lease extensions
+# script-on-renewal
+
+# ============================================
+# Optional: Read-only Lease File Mode
+# ============================================
+
+# Uncomment for advanced setups where lease-sync daemon manages the lease database
+# In this mode:
+#   - dnsmasq does NOT write to lease file
+#   - Script receives "init" call on startup and should output leases
+#   - lease-sync daemon is responsible for lease persistence
+#
+# leasefile-ro
+
+# ============================================
+# DHCPv6 Configuration (if using IPv6)
+# ============================================
+
+# Enable DHCPv6
+# dhcp-range=::100,::1ff,constructor:br-lan,ra-stateless,12h
+
+# Enable Router Advertisement
+# enable-ra
+
+# ============================================
+# DNS Configuration
+# ============================================
+
+# Don't read /etc/hosts
+# no-hosts
+
+# Don't read /etc/resolv.conf
+# no-resolv
+
+# Upstream DNS servers
+server=8.8.8.8
+server=8.8.4.4
+
+# Expand simple names (add domain suffix)
+expand-hosts
+
+# Set the size of dnsmasq's cache
+cache-size=1000
+
+# ============================================
+# Logging (useful for debugging)
+# ============================================
+
+# Log lots of extra information about DHCP transactions
+# log-dhcp
+
+# Log queries
+# log-queries
+
+# Log to specific file (default is syslog)
+# log-facility=/var/log/dnsmasq.log
+
+# ============================================
+# ubus Integration
+# ============================================
+
+# Enable ubus support (required for lease-sync)
+# This is typically compiled in on OpenWrt
+# enable-ubus
+
+# Optional: Set ubus service name
+# ubus-name=dnsmasq
+
+# ============================================
+# Static DHCP Leases
+# ============================================
+
+# Example static leases
+# These will be automatically synced to peer nodes
+# dhcp-host=aa:bb:cc:dd:ee:ff,192.168.1.10,server1,infinite
+# dhcp-host=11:22:33:44:55:66,192.168.1.11,server2,infinite
+
+# ============================================
+# DHCP Options
+# ============================================
+
+# Router (default gateway)
+dhcp-option=3,192.168.1.1
+
+# DNS server (point to this dnsmasq instance)
+dhcp-option=6,192.168.1.1
+
+# NTP server
+# dhcp-option=42,192.168.1.1
+
+# Domain name
+dhcp-option=15,lan
+
+# ============================================
+# Advanced Options
+# ============================================
+
+# Ignore DHCP requests from unknown hosts (strict security)
+# dhcp-ignore=tag:!known
+
+# Bind only to specific interfaces (security)
+interface=br-lan
+
+# Don't bind to wildcard addresses
+bind-interfaces
+
+# Enable rapid commit (2-message exchange instead of 4)
+# dhcp-rapid-commit
+
+# ============================================
+# HA-Specific Tuning
+# ============================================
+
+# Reduce lease time for faster failover detection
+# For production HA, consider shorter leases (e.g., 1h instead of 12h)
+# dhcp-range=192.168.1.50,192.168.1.200,1h
+
+# Increase DHCP authoritative mode aggressiveness
+# Helps with faster lease takeover on failover
+dhcp-authoritative
+
+# Ignore requests for unknown leases (let peer handle them)
+# This prevents both nodes from responding to the same DISCOVER
+# Note: Only use this if you have proper load balancing configured
+# dhcp-ignore=tag:!known
+
+# ============================================
+# Monitoring and Metrics
+# ============================================
+
+# Enable metrics collection (for monitoring via ubus)
+# Available via: ubus call dnsmasq metrics
+# (Enabled by default in OpenWrt builds)
diff --git a/contrib/lease-sync/files/lease-sync.init b/contrib/lease-sync/files/lease-sync.init
new file mode 100644
index 0000000..e74ac4f
--- /dev/null
+++ b/contrib/lease-sync/files/lease-sync.init
@@ -0,0 +1,76 @@
+#!/bin/sh /etc/rc.common
+# Copyright (C) 2025
+# lease-sync daemon init script for OpenWrt (procd)
+
+START=99
+STOP=10
+
+USE_PROCD=1
+
+PROG=/usr/sbin/lease-sync
+CONF=/etc/lease-sync/config
+
+start_service() {
+    # Ensure configuration directory exists
+    [ -d /etc/lease-sync ] || mkdir -p /etc/lease-sync
+    [ -d /var/lib/lease-sync ] || mkdir -p /var/lib/lease-sync
+
+    # Check if configuration file exists
+    if [ ! -f "$CONF" ]; then
+        logger -t lease-sync -p daemon.warning "Configuration file not found: $CONF"
+        logger -t lease-sync -p daemon.warning "Creating default configuration..."
+
+        cat > "$CONF" <<EOF
+# Auto-generated lease-sync configuration
+# Edit this file to add peer nodes
+
+# Peer configuration (add your peer nodes here)
+# peer=192.168.1.10
+# peer=192.168.1.11
+
+sync_port=5378
+sync_interval=30
+persist_interval=60
+peer_timeout=120
+log_level=2
+EOF
+    fi
+
+    procd_open_instance lease-sync
+    procd_set_param command "$PROG" -c "$CONF"
+
+    # Respawn settings
+    procd_set_param respawn ${respawn_threshold:-3600} ${respawn_timeout:-5} ${respawn_retry:-5}
+
+    # File descriptor limits
+    procd_set_param limits nofile="1024 1024"
+
+    # Standard streams
+    procd_set_param stdout 1
+    procd_set_param stderr 1
+
+    # Use syslog for logging
+    procd_set_param syslog 1
+
+    procd_close_instance
+
+    logger -t lease-sync -p daemon.info "Starting lease-sync daemon"
+}
+
+stop_service() {
+    logger -t lease-sync -p daemon.info "Stopping lease-sync daemon"
+}
+
+service_triggers() {
+    # Reload on network changes
+    procd_add_reload_trigger "network"
+
+    # Watch configuration file for changes
+    procd_add_reload_trigger "lease-sync"
+}
+
+reload_service() {
+    logger -t lease-sync -p daemon.info "Reloading lease-sync daemon"
+    stop
+    start
+}
