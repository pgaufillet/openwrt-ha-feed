+static void build_suppressed_event_path(const char *ip, uint8_t action, char *path, size_t path_len)
+{
+  char key[INET6_ADDRSTRLEN * 2];
+  size_t pos = 0;
+  const unsigned char *p;
+
+  if (!path || path_len == 0)
+    return;
+
+  if (!ip)
+    ip = "";
+
+  for (p = (const unsigned char *)ip; *p && pos < sizeof(key) - 1; p++)
+    {
+      if (isalnum(*p) || *p == '.' || *p == '_' || *p == '-')
+        key[pos++] = (char)*p;
+      else
+        key[pos++] = '_';
+    }
+  key[pos] = '\0';
+
+  snprintf(path, path_len, "%s/%s_%s", SUPPRESSED_EVENT_DIR,
+           suppressed_action_name(action), key);
+}
+
+static void write_suppressed_event_marker(const char *ip, uint8_t action, uint64_t expires_ms)
+{
+  char path[sizeof(SUPPRESSED_EVENT_DIR) + INET6_ADDRSTRLEN * 2 + 16];
+  FILE *f;
+
+  if (!ip || !*ip || action == 0)
+    return;
+
+  if (mkdir(SUPPRESSED_EVENT_PARENT_DIR, 0755) < 0 && errno != EEXIST)
+    return;
+  if (mkdir(SUPPRESSED_EVENT_DIR, 0755) < 0 && errno != EEXIST)
+    return;
+
+  build_suppressed_event_path(ip, action, path, sizeof(path));
+  f = fopen(path, "w");
+  if (!f)
+    return;
+
+  fprintf(f, "%llu\n", (unsigned long long)((expires_ms + 999) / 1000));
+  fclose(f);
+}
+
+static void remove_suppressed_event_marker(const char *ip, uint8_t action)
+{
+  char path[sizeof(SUPPRESSED_EVENT_DIR) + INET6_ADDRSTRLEN * 2 + 16];
+
+  if (!ip || !*ip || action == 0)
+    return;
+
+  build_suppressed_event_path(ip, action, path, sizeof(path));
+  unlink(path);
+}
