+static bool lease_entry_has_valid_mac(const struct lease_entry *entry)
+{
+  unsigned char mac[6];
+  int len = 0;
+
+  if (!entry || !entry->mac[0])
+    return false;
+
+  if (parse_mac(entry->mac, mac, sizeof(mac), &len) < 0)
+    return false;
+
+  return len == 6;
+}
+
+bool lease_entry_has_dhcpv6_identity(const struct lease_entry *entry)
+{
+  return entry && entry->af_family == AF_INET6 && entry->client_id_len > 0;
+}
+
+bool lease_entry_same_dhcpv6_identity(const struct lease_entry *a, const struct lease_entry *b)
+{
+  if (!lease_entry_has_dhcpv6_identity(a) || !lease_entry_has_dhcpv6_identity(b))
+    return false;
+
+  if (a->iaid != b->iaid || a->is_temporary != b->is_temporary ||
+      a->client_id_len != b->client_id_len)
+    return false;
+
+  return memcmp(a->client_id, b->client_id, a->client_id_len) == 0;
+}
+
+int lease_entry_compare_dhcpv6_authority(const struct lease_entry *candidate,
+                                         const struct lease_entry *current)
+{
+  int source_cmp;
+
+  if (!candidate || !current)
+    return 0;
+
+  source_cmp = strcmp(candidate->source_node, current->source_node);
+  if (source_cmp != 0)
+    return source_cmp < 0 ? 1 : -1;
+
+  if (candidate->timestamp_ms != current->timestamp_ms)
+    return candidate->timestamp_ms > current->timestamp_ms ? 1 : -1;
+
+  source_cmp = strcmp(candidate->ip_str, current->ip_str);
+  if (source_cmp != 0)
+    return source_cmp < 0 ? 1 : -1;
+
+  return 0;
+}
+
+struct lease_entry *lease_db_find_dhcpv6_identity(const struct lease_entry *needle, const char *exclude_ip)
+{
+  int i;
+
+  if (!g_state || !lease_entry_has_dhcpv6_identity(needle))
+    return NULL;
+
+  for (i = 0; i < HASH_TABLE_SIZE; i++)
+    {
+      struct lease_entry *entry = g_state->lease_table[i];
+
+      while (entry)
+        {
+          if ((!exclude_ip || strcmp(entry->ip_str, exclude_ip) != 0) &&
+              lease_entry_same_dhcpv6_identity(entry, needle))
+            return entry;
+
+          entry = entry->next;
+        }
+    }
+
+  return NULL;
+}
