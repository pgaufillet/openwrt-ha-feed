 /* ============================================
+ * Test: DHCPv6 DUID prefix must not be treated as MAC
+ * ============================================ */
+void test_dhcpv6_similar_duid_prefixes_do_not_conflict(void)
+{
+    printf("\n=== Test: DHCPv6 similar DUID prefixes do not conflict ===\n");
+
+    reset_state();
+
+    const unsigned char duid1[] = {
+        0x00, 0x04, 0xff, 0xeb, 0xd5, 0x7c, 0xfd, 0x47,
+        0xd5, 0x30, 0x28, 0xb5, 0x19, 0x3e, 0xce, 0xcd,
+        0x8b, 0x88
+    };
+    const unsigned char duid2[] = {
+        0x00, 0x04, 0xff, 0xeb, 0xd5, 0x7c, 0x01, 0x18,
+        0x67, 0xef, 0x5f, 0x00, 0x99, 0xaa, 0xbb, 0xcc,
+        0xdd, 0xee
+    };
+    struct lease_entry lease;
+
+    make_dhcpv6_lease(&lease, "fd00:1234:abcd:1::e1a0",
+                      duid1, sizeof(duid1), 42, "nut", 1000, "node-a");
+    lease_db_add(&lease);
+
+    make_dhcpv6_lease(&lease, "fd00:1234:abcd:1::ea4d",
+                      duid2, sizeof(duid2), 42, "mangopimcore", 2000, "node-b");
+    lease_db_add(&lease);
+
+    if (lease_db_count() == 2) {
+        TEST_PASS("Both DHCPv6 leases are stored independently");
+    } else {
+        TEST_FAIL("Both DHCPv6 leases are stored independently", "lease count changed");
+    }
+
+    if (g_state->total_conflicts_resolved == 0) {
+        TEST_PASS("Similar DUID prefixes did not increment conflict counter");
+    } else {
+        TEST_FAIL("Similar DUID prefixes did not increment conflict counter",
+                  "false conflict detected");
+    }
+}
