+static bool resolve_dhcpv6_identity_conflict(struct lease_entry *entry)
+{
+  struct lease_entry *conflict;
+
+  if (!lease_entry_has_dhcpv6_identity(entry))
+    {
+      if (entry->af_family == AF_INET6)
+        log_warning("Ignoring DHCPv6 lease %s from %s with incomplete client identity",
+                    entry->ip_str, entry->source_node);
+      return entry->af_family != AF_INET6;
+    }
+
+  conflict = lease_db_find_dhcpv6_identity(entry, entry->ip_str);
+  if (!conflict)
+    return true;
+
+  if (lease_entry_compare_dhcpv6_authority(entry, conflict) <= 0)
+    {
+      log_info("Ignoring DHCPv6 lease %s from %s; keeping %s from %s for same client identity",
+               entry->ip_str, entry->source_node, conflict->ip_str,
+               conflict->source_node);
+      peer_sync_broadcast_lease(conflict, SYNC_ACTION_UPDATE);
+      return false;
+    }
+  else
+    {
+      char stale_ip[INET6_ADDRSTRLEN];
+
+      strncpy(stale_ip, conflict->ip_str, sizeof(stale_ip) - 1);
+      stale_ip[sizeof(stale_ip) - 1] = '\0';
+
+      log_warning("Replacing DHCPv6 lease %s from %s with %s from %s for same client identity",
+                  stale_ip, conflict->source_node, entry->ip_str, entry->source_node);
+
+      lease_db_delete(stale_ip);
+      if (ubus_handler_delete_lease(stale_ip) < 0)
+        {
+          struct lease_entry stale;
+
+          memset(&stale, 0, sizeof(stale));
+          strncpy(stale.ip_str, stale_ip, sizeof(stale.ip_str) - 1);
+          retry_queue_add(&g_state->retry_queue, &stale, RETRY_ACTION_DELETE);
+        }
+    }
+
+  return true;
+}
