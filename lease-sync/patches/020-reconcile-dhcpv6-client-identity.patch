+struct lease_entry *lease_db_find_dhcpv6_identity_conflict(const struct lease_entry *new_entry)
+{
+  int i;
+
+  if (!g_state || !new_entry || new_entry->af_family != AF_INET6 ||
+      new_entry->client_id_len <= 0)
+    return NULL;
+
+  for (i = 0; i < HASH_TABLE_SIZE; i++)
+    {
+      struct lease_entry *entry = g_state->lease_table[i];
+
+      while (entry)
+        {
+          if (entry->af_family == AF_INET6 &&
+              strcmp(entry->ip_str, new_entry->ip_str) != 0 &&
+              entry->client_id_len > 0 &&
+              entry->iaid == new_entry->iaid &&
+              entry->is_temporary == new_entry->is_temporary &&
+              lease_client_id_equal(entry, new_entry))
+            return entry;
+
+          entry = entry->next;
+        }
+    }
+
+  return NULL;
+}
