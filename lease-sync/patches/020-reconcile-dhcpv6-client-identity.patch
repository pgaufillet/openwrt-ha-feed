+static bool reconcile_dhcpv6_identity_conflict(struct lease_entry *entry)
+{
+  struct lease_entry *conflict;
+  struct lease_entry stale;
+  char client_id[MAX_CLIENT_ID_LEN * 3];
+
+  conflict = lease_db_find_dhcpv6_identity_conflict(entry);
+  if (!conflict)
+    return true;
+
+  if (conflict->timestamp_ms >= entry->timestamp_ms)
+    {
+      log_info("Ignoring DHCPv6 lease %s: existing lease %s for same client_id/iaid is same or newer (%llu >= %llu)",
+               entry->ip_str, conflict->ip_str,
+               (unsigned long long)conflict->timestamp_ms,
+               (unsigned long long)entry->timestamp_ms);
+      return false;
+    }
+
+  memset(client_id, 0, sizeof(client_id));
+  if (!format_mac(entry->client_id, entry->client_id_len,
+                  client_id, sizeof(client_id)))
+    strncpy(client_id, "<invalid>", sizeof(client_id) - 1);
+
+  memcpy(&stale, conflict, sizeof(stale));
+  stale.next = NULL;
+
+  log_warning("DHCPv6 identity conflict for client_id %s iaid %u: replacing stale lease %s with peer lease %s",
+              client_id, entry->iaid, stale.ip_str, entry->ip_str);
+
+  lease_db_delete(stale.ip_str);
+
+  if (ubus_handler_delete_lease(stale.ip_str) < 0)
+    {
+      log_warning("Failed to delete stale DHCPv6 lease %s, queuing for retry",
+                  stale.ip_str);
+      retry_queue_add(&g_state->retry_queue, &stale, RETRY_ACTION_DELETE);
+    }
+
+  g_state->total_conflicts_resolved++;
+
+  return true;
+}
