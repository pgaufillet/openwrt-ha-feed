#!/bin/sh

# Keep DHCPv6 and router advertisements active only on the current authoritative
# MASTER node. dnsmasq must keep DHCPv6 initialized so lease-sync can inject
# peer leases over ubus, but BACKUP nodes must not serve clients or advertise
# themselves as routers.

[ "$TYPE" = "INSTANCE" ] || exit 0

. /lib/functions.sh

config_load ha-cluster
config_get_bool enabled config enabled 0
config_get_bool sync_leases dhcp sync_leases 0

[ "$enabled" -eq 1 ] || exit 0
[ "$sync_leases" -eq 1 ] || exit 0

NFT="/usr/sbin/nft"
TABLE="ha_cluster_dhcpv6"
INPUT_CHAIN="backup_input"
OUTPUT_CHAIN="backup_output"
INPUT_COMMENT="ha-cluster block DHCPv6 requests while BACKUP"
OUTPUT_COMMENT="ha-cluster block DHCPv6 replies while BACKUP"
RA_COMMENT="ha-cluster block IPv6 router advertisements while BACKUP"
STATE_DIR="/tmp/ha-cluster/dhcpv6-state"
ROLE_FILE="/tmp/ha-cluster/dhcpv6-role"

safe_name="$(printf '%s' "$NAME" | tr -c 'A-Za-z0-9_.-' '_')"
mkdir -p "$STATE_DIR"

case "$ACTION" in
	MASTER|BACKUP|FAULT|STOP)
		echo "$ACTION" > "$STATE_DIR/$safe_name"
		;;
	*)
		exit 0
		;;
esac

has_master=0
for state_file in "$STATE_DIR"/*; do
	[ -f "$state_file" ] || continue
	state="$(cat "$state_file" 2>/dev/null)"
	[ "$state" = "MASTER" ] && {
		has_master=1
		break
	}
done

block_dhcpv6() {
	if [ ! -x "$NFT" ]; then
		logger -t ha-cluster -p daemon.warning "nft is not available, cannot block DHCPv6 on BACKUP"
		return 1
	fi

	"$NFT" list table inet "$TABLE" >/dev/null 2>&1 || \
		"$NFT" add table inet "$TABLE"

	"$NFT" list chain inet "$TABLE" "$INPUT_CHAIN" >/dev/null 2>&1 || \
		"$NFT" add chain inet "$TABLE" "$INPUT_CHAIN" '{ type filter hook input priority -50; policy accept; }'

	"$NFT" list chain inet "$TABLE" "$OUTPUT_CHAIN" >/dev/null 2>&1 || \
		"$NFT" add chain inet "$TABLE" "$OUTPUT_CHAIN" '{ type filter hook output priority -50; policy accept; }'

	"$NFT" -a list chain inet "$TABLE" "$INPUT_CHAIN" 2>/dev/null | grep -q "$INPUT_COMMENT" || \
		"$NFT" add rule inet "$TABLE" "$INPUT_CHAIN" meta nfproto ipv6 udp dport 547 counter drop comment "\"$INPUT_COMMENT\""

	"$NFT" -a list chain inet "$TABLE" "$OUTPUT_CHAIN" 2>/dev/null | grep -q "$OUTPUT_COMMENT" || \
		"$NFT" add rule inet "$TABLE" "$OUTPUT_CHAIN" meta nfproto ipv6 udp sport 547 counter drop comment "\"$OUTPUT_COMMENT\""

	"$NFT" -a list chain inet "$TABLE" "$OUTPUT_CHAIN" 2>/dev/null | grep -q "$RA_COMMENT" || \
		"$NFT" add rule inet "$TABLE" "$OUTPUT_CHAIN" meta nfproto ipv6 ip6 nexthdr icmpv6 icmpv6 type nd-router-advert counter drop comment "\"$RA_COMMENT\""

	logger -t ha-cluster -p daemon.info "DHCPv6 server traffic and router advertisements blocked while BACKUP"
}

unblock_dhcpv6() {
	[ -x "$NFT" ] || return 0

	"$NFT" delete table inet "$TABLE" >/dev/null 2>&1
	logger -t ha-cluster -p daemon.info "DHCPv6 server traffic and router advertisements unblocked on MASTER"
}

if [ "$has_master" -eq 1 ]; then
	echo "MASTER" > "$ROLE_FILE"
	unblock_dhcpv6
else
	echo "BACKUP" > "$ROLE_FILE"
	block_dhcpv6
fi
