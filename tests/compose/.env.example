# HA Cluster Test Environment Configuration
#
# Copy to .env and customize as needed:
#   cp .env.example .env

# Container runtime (podman or docker)
CONTAINER_RUNTIME=podman

# Image names
NODE_IMAGE=ha-cluster-node:latest
CLIENT_IMAGE=ha-dhcp-client:latest

# Network settings
BACKEND_SUBNET=172.30.0.0/24
CLIENT_SUBNET=192.168.50.0/24

# VIP settings
VIP_ADDRESS=192.168.50.254
VIP_NETMASK=255.255.255.0
VIP_VRID=51

# Test encryption key (64 hex chars = 256 bits)
ENCRYPTION_KEY=7f8e9d0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e

# Timeouts (seconds)
BOOT_TIMEOUT=30
FAILOVER_TIMEOUT=10
SYNC_TIMEOUT=15
